APP_NAME=news-parser-api
ENVIRONMENT=local
LOG_LEVEL=INFO

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=news_parser
POSTGRES_USER=news_parser
POSTGRES_PASSWORD=news_parser

DATABASE_URL=postgresql+asyncpg://news_parser:news_parser@db:5432/news_parser
REDIS_URL=redis://redis:6379/0
REDIS_RAW_NEWS_CHANNEL=news.raw
REDIS_ENRICHMENT_STREAM=news.enrichment
REDIS_ENRICHED_CHANNEL=news.enriched
REDIS_NEWS_CACHE_KEY=news.cache
REDIS_CONSUMER_GROUP=enrichment-workers
REDIS_NEWS_CACHE_SIZE=200

GROQ_API_KEY=replace-me

TELEGRAM_API_ID=000000
TELEGRAM_API_HASH=replace-me
TELEGRAM_SESSION_NAME=news-parser
TELEGRAM_CLIENT=pyrogram
TELEGRAM_CHANNELS=@channel_one,@channel_two,https://t.me/channel_three
TELEGRAM_TARGET_CHANNEL=@Tasnimnews

TRUTH_SOCIAL_ACCESS_TOKEN=replace-me
